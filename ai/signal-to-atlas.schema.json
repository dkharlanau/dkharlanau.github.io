{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dkharlanau.github.io/ai/signal-to-atlas.schema.json",
  "title": "Signal to Atlas Update Decision",
  "description": "Compact schema for source-backed professional signals that may update Atlas pages.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "record_id",
    "state",
    "signal",
    "evidence",
    "classification",
    "decision"
  ],
  "properties": {
    "schema": {
      "const": "dkharlanau.signal_to_atlas"
    },
    "schema_version": {
      "const": "1.0"
    },
    "record_id": {
      "type": "string",
      "minLength": 3
    },
    "state": {
      "type": "string",
      "enum": [
        "RAW_SIGNAL",
        "ENRICHED_SIGNAL",
        "MATCHED_TO_ATLAS",
        "UPDATE_PROPOSED",
        "REVIEW_READY",
        "APPROVED",
        "REJECTED",
        "NEEDS_RESEARCH"
      ]
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "source_name",
        "source_url",
        "source_date",
        "date_checked",
        "source_type"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 5
        },
        "source_name": {
          "type": "string",
          "minLength": 2
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "source_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "date_checked": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "author_or_org": {
          "type": "string"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "official_vendor",
            "official_docs",
            "customer_story",
            "partner_case",
            "analyst_news",
            "community_blog",
            "product_release",
            "security_note",
            "manual_research"
          ]
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_body_opened",
        "concrete_facts",
        "product_names",
        "named_components",
        "numbers",
        "examples"
      ],
      "properties": {
        "source_body_opened": {
          "type": "boolean"
        },
        "concrete_facts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 8
          },
          "minItems": 0,
          "maxItems": 8
        },
        "product_names": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 8
        },
        "named_components": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 12
        },
        "numbers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 8
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 6
        },
        "evidence_notes": {
          "type": "string"
        }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sap_domain",
        "business_process",
        "technology_area",
        "operational_implication",
        "tags"
      ],
      "properties": {
        "sap_domain": {
          "type": "string"
        },
        "business_process": {
          "type": "string"
        },
        "technology_area": {
          "type": "string"
        },
        "operational_implication": {
          "type": "string",
          "minLength": 10
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "minItems": 1,
          "maxItems": 12
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_decision",
        "decision_reason",
        "review_status"
      ],
      "properties": {
        "target_decision": {
          "type": "string",
          "enum": [
            "update_existing_page",
            "create_new_page_candidate",
            "reject",
            "needs_research"
          ]
        },
        "decision_reason": {
          "type": "string",
          "minLength": 12
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "needs_research",
            "ready_for_review",
            "approved",
            "rejected"
          ]
        },
        "rejection_reason": {
          "type": "string"
        }
      }
    },
    "atlas_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "url",
          "title",
          "score",
          "match_reasons"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^atlas/.+\\.md$"
          },
          "url": {
            "type": "string",
            "pattern": "^/atlas/.+/$"
          },
          "title": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "match_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "maxItems": 8
          }
        }
      },
      "default": []
    },
    "proposed_update": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_path",
        "proposed_section_heading",
        "proposed_content_block",
        "source_attribution_block",
        "risks",
        "validation_checklist"
      ],
      "properties": {
        "target_path": {
          "type": "string",
          "pattern": "^atlas/.+\\.md$"
        },
        "proposed_section_heading": {
          "type": "string"
        },
        "proposed_content_block": {
          "type": "string",
          "minLength": 40
        },
        "source_attribution_block": {
          "type": "string",
          "minLength": 20
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 8
        },
        "validation_checklist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 3,
          "maxItems": 12
        }
      }
    },
    "proposed_new_page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proposed_path",
        "title",
        "atlas_section",
        "noindex_until_reviewed",
        "related_pages",
        "why_existing_pages_are_insufficient"
      ],
      "properties": {
        "proposed_path": {
          "type": "string",
          "pattern": "^atlas/.+\\.md$"
        },
        "title": {
          "type": "string"
        },
        "atlas_section": {
          "type": "string"
        },
        "noindex_until_reviewed": {
          "const": true
        },
        "related_pages": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^/atlas/.+/$"
          },
          "minItems": 1
        },
        "why_existing_pages_are_insufficient": {
          "type": "string",
          "minLength": 20
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "target_decision": {
                "const": "update_existing_page"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "atlas_candidates",
          "proposed_update"
        ],
        "properties": {
          "evidence": {
            "properties": {
              "source_body_opened": {
                "const": true
              },
              "concrete_facts": {
                "minItems": 2
              }
            }
          },
          "atlas_candidates": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "target_decision": {
                "const": "create_new_page_candidate"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "atlas_candidates",
          "proposed_new_page",
          "proposed_update"
        ],
        "properties": {
          "evidence": {
            "properties": {
              "source_body_opened": {
                "const": true
              },
              "concrete_facts": {
                "minItems": 2
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "target_decision": {
                "enum": [
                  "reject",
                  "needs_research"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "required": [
              "rejection_reason"
            ]
          }
        }
      }
    }
  ]
}
