---
layout: null
permalink: /blog/feed.xml
sitemap: false
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
  <id>{{ '/blog/' | absolute_url }}</id>
  <title>{{ site.title }} | Blog</title>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <link href="{{ page.url | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/blog/' | absolute_url }}" rel="alternate" type="text/html" />
  <author><name>{{ site.author.name }}</name></author>
  {% assign posts = site.blog | where: 'verified', true | where: 'status', 'reviewed' | sort: 'date' | reverse %}
  {% for post in posts %}
  <entry>
    <id>{{ post.url | absolute_url }}</id>
    <title type="html">{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_modified_at | default: post.updated | default: post.date | date_to_xmlschema }}</updated>
    <summary type="html">{{ post.description | xml_escape }}</summary>
  </entry>
  {% endfor %}
</feed>
